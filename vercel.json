{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "redirects": [
    {
      "source": "/",
      "has": [
        {
          "type": "host",
          "value": "Kinofedia-build.vercel.app"
        }
      ],
      "destination": "https://kinofedia.nl",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "Kinofedia-build.vercel.app"
        }
      ],
      "destination": "https://kinofedia.nl/:path*",
      "permanent": true
    }
  ]
}
